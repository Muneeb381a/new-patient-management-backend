# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis — set this to enable caching (optional, app works without it)
# Upstash Redis (recommended for Vercel): redis://default:password@host.upstash.io:6379
# Redis Cloud / self-hosted:             redis://default:password@host:6379
REDIS_URL=

# App
NODE_ENV=production
PORT=4500
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=10000
