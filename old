// 404 handler
app.use((req, res, next) => {
  next(new ApiError(404, `Resource not found: ${req.method} ${req.path}`));
});

// Global error handler
app.use((err, req, res, next) => {
  const statusCode = err.statusCode || 500;
  const message = config.server.env === "production" && statusCode === 500 
    ? "Internal Server Error" 
    : err.message;

  // Log detailed error information
  console.error({
    error: {
      message: err.message,
      stack: config.server.env === "development" ? err.stack : undefined,
      status: statusCode,
      path: req.path,
      method: req.method,
      timestamp: new Date().toISOString()
    }
  });

  res.status(statusCode).json({
    success: false,
    message,
    ...(config.server.env === "development" && { error: err })
  });
});

