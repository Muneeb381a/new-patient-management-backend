import express from "express";
import fs from "fs";
import cors from "cors";
import { ApiError } from "./utils/ApiError.js";

// Custom environment loader
const loadEnvironment = () => {
  try {
    const envFile = fs.readFileSync('./.env', 'utf8');
    envFile.split('\n').forEach(line => {
      const [key, ...values] = line.split('=');
      const value = values.join('=').trim().replace(/^"(.*)"$/, '$1');
      if (key && !key.startsWith('#')) {
        process.env[key.trim()] = value;
      }
    });
  } catch (error) {
    console.warn('⚠️ No .env file found, using process environment');
  }
};
loadEnvironment();

const app = express();

// ========================
//      Configuration
// ========================
const config = {
  rateLimit: {
    windowMs: 15 * 60 * 1000, // 15 minutes
    max: 100, // Limit each IP to 100 requests per window
    message: 'Too many requests, please try again later'
  },
  security: {
    cors: {
      allowedOrigins: new Set([
        process.env.FRONTEND_URL || 'http://localhost:5173',
        'https://prescription-frontend.vercel.app'
      ])
    },
    headers: {
      hsts: 'max-age=31536000; includeSubDomains'
    }
  },
  server: {
    port: process.env.PORT || 4500,
    jsonLimit: '16kb'
  }
};

// ========================
//      Rate Limiter
// ========================
const requestStore = new Map();

const rateLimiter = () => {
  // Cleanup old entries every minute
  setInterval(() => {
    const now = Date.now();
    for (const [ip, entry] of requestStore) {
      if (entry.expiresAt < now) requestStore.delete(ip);
    }
  }, 60 * 1000);

  return (req, res, next) => {
    const ip = req.ip || req.socket.remoteAddress;
    const currentTime = Date.now();

    if (!requestStore.has(ip)) {
      requestStore.set(ip, {
        count: 1,
        expiresAt: currentTime + config.rateLimit.windowMs
      });
      return next();
    }

    const entry = requestStore.get(ip);
    if (currentTime > entry.expiresAt) {
      requestStore.set(ip, {
        count: 1,
        expiresAt: currentTime + config.rateLimit.windowMs
      });
      return next();
    }

    if (entry.count >= config.rateLimit.max) {
      return next(new ApiError(429, config.rateLimit.message));
    }

    entry.count++;
    next();
  };
};

// ========================
//      Core Middleware
// ========================
app.use(cors({
  origin: (origin, callback) => {
    if (!origin || config.security.cors.allowedOrigins.has(origin)) {
      callback(null, true);
    } else {
      callback(new ApiError(403, 'Not allowed by CORS'));
    }
  },
  credentials: true
}));

app.use(express.json({ limit: config.server.jsonLimit }));
app.use(express.urlencoded({ extended: true, limit: config.server.jsonLimit }));
app.use(express.static('public'));

// Security headers middleware
app.use((req, res, next) => {
  res.removeHeader('X-Powered-By');
  res.setHeader('X-Content-Type-Options', 'nosniff');
  res.setHeader('X-Frame-Options', 'DENY');
  res.setHeader('Strict-Transport-Security', config.security.headers.hsts);
  next();
});

// Apply rate limiter to all routes
app.use(rateLimiter());

// ========================
//      Route Handling
// ========================
// Health check endpoint
app.get('/health', (req, res) => {
  res.json({
    status: 'OK',
    timestamp: new Date().toISOString(),
    uptime: process.uptime(),
    memoryUsage: process.memoryUsage()
  });
});

// Base Route
app.get('/', (req, res) => {
  res.json({
    message: 'Clinic Management System API',
    version: '1.0.0',
    environment: process.env.NODE_ENV || 'development',
    documentation: '/api-docs'
  });
});

