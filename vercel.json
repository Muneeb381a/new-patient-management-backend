{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/db-keepalive",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/follow-up-reminders",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/suggest/process-feedback",
      "schedule": "0 2 * * *"
    }
  ]
}
